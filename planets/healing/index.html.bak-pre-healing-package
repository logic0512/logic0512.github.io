    function makeVoidCanvas(width, height, palette) {
      const c = document.createElement('canvas');
      c.width = width;
      c.height = height;
      const ctx = c.getContext('2d');
      ctx.fillStyle = palette.base;
      ctx.fillRect(0, 0, width, height);

      addRadial(ctx, width * 0.18, height * 0.16, width * 0.86, palette.glowA, 'rgba(255, 248, 232, 0)');
      addRadial(ctx, width * 0.72, height * 0.32, width * 0.76, palette.glowB, 'rgba(235, 244, 239, 0)');
      addRadial(ctx, width * 0.52, height * 0.84, width * 0.70, palette.glowC, 'rgba(238, 242, 252, 0)');
      addRadial(ctx, width * 0.46, height * 0.44, width * 0.54, 'rgba(255, 255, 255, 0.26)', 'rgba(255, 255, 255, 0)');

      const starCount = 340;
      for (let i = 0; i < starCount; i++) {
        const x = Math.random() * width;
        const y = Math.random() * height;
        const tiny = Math.random();
        const r = tiny < 0.92 ? 0.35 + Math.random() * 0.45 : 0.8 + Math.random() * 0.95;
        const alpha = tiny < 0.92 ? 0.11 + Math.random() * 0.2 : 0.22 + Math.random() * 0.28;
        ctx.fillStyle = `rgba(${palette.speck}, ${alpha.toFixed(3)})`;
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fill();
      }
      return c;
    }

    function addRadial(ctx, x, y, r, a, b) {
      const g = ctx.createRadialGradient(x, y, 0, x, y, r);
      g.addColorStop(0, a);
      g.addColorStop(1, b);
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, ctx.canvas.width, ctx.canvas.height);
    }

    function createParticles() {
      const count = 150;
      const positions = new Float32Array(count * 3);
      const colors = new Float32Array(count * 3);
      const colorA = new THREE.Color(0xfff4d7);
      const colorB = new THREE.Color(0xf1b99a);
      for (let i = 0; i < count; i++) {
        positions[i * 3 + 0] = (Math.random() - 0.5) * 18;
        positions[i * 3 + 1] = (Math.random() - 0.5) * 9;
        positions[i * 3 + 2] = -Math.random() * FIELD_DEPTH - 2;
        const color = colorA.clone().lerp(colorB, Math.random() * 0.7);
        colors[i * 3 + 0] = color.r;
        colors[i * 3 + 1] = color.g;
        colors[i * 3 + 2] = color.b;
      }
      const geo = new THREE.BufferGeometry();
      geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
      geo.setAttribute('color', new THREE.BufferAttribute(colors, 3));
      const mat = new THREE.PointsMaterial({
        size: 0.045,
        sizeAttenuation: true,
        vertexColors: true,
        transparent: true,
        opacity: 0.42,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      });
      particleGroup.add(new THREE.Points(geo, mat));
    }

    function flyInNewCard(newId) {
      // 找被标记 spawning 的那一份（buildCards 只标第一份）
      const mesh = cardMeshes.find(m => m.userData.record.id === newId && m.userData.spawning)
                || cardMeshes.find(m => m.userData.record.id === newId);
      if (!mesh || typeof gsap === 'undefined') return;

      // 终点 = 卡片已经在 buildCards 里确定的位置
      const finalPos = mesh.position.clone();
      const finalScale = 1;
      const finalOpacity = mesh.userData.base.opacity || 1;

      // 起点 = 相机正前方 ~2.4 单位（即用户刚刚看 composer 的位置）
      const camForward = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion);
      const startPos = camera.position.clone().add(camForward.clone().multiplyScalar(2.4));

      // 控制点 = 起点→终点中点 + 垂直方向 hash 偏移 → 每张卡曲线不一样
      const idHash = hashId(newId);
      const midPos = startPos.clone().lerp(finalPos, 0.5);
      const dirToFinal = finalPos.clone().sub(startPos).normalize();
      const camUp = new THREE.Vector3(0, 1, 0).applyQuaternion(camera.quaternion);
      const perp = new THREE.Vector3().crossVectors(dirToFinal, camUp).normalize();
      const sideAmount = ((idHash % 1000) / 1000 - 0.5) * 5.0;
      const upAmount = ((idHash % 71) / 71 - 0.15) * 3.5;
      const ctrlPos = midPos
        .add(perp.multiplyScalar(sideAmount))
        .add(camUp.clone().multiplyScalar(upAmount));

      mesh.position.copy(startPos);
      mesh.scale.setScalar(0.35);
      mesh.material.opacity = 0;
      mesh.userData.spawning = true;
      mesh.userData.currentScale = 0.35;
      mesh.userData.targetScale = 1;

      const halo = makeHaloMesh(mesh);
      mesh.add(halo);

      // 相机引导：朝向 finalPos
      const camTarget = computeYawPitchTo(finalPos.clone().sub(camera.position));
      const yawDelta = shortestAngleDelta(targetYaw, camTarget.yaw);
      const pitchDelta = camTarget.pitch - targetPitch;
      velocityYaw = 0;
      velocityPitch = 0;
      targetYaw += yawDelta * 0.92;
      targetPitch = Math.max(-PITCH_LIMIT, Math.min(PITCH_LIMIT, targetPitch + pitchDelta * 0.92));

      // bezier 轨迹 · 每张卡独立曲线
      const t = { value: 0 };
      const tl = gsap.timeline({
        onComplete: () => {
          mesh.userData.spawning = false;
          mesh.userData.currentScale = finalScale;
          mesh.userData.targetScale = finalScale;
          mesh.position.copy(finalPos);
          mesh.remove(halo);
          halo.geometry.dispose();
          halo.material.map?.dispose();
          halo.material.dispose();
        }
      });

      tl.to(t, {
        value: 1,
        duration: 2.4,
        ease: 'power3.out',
        onUpdate: () => {
          const tt = t.value;
          const omt = 1 - tt;
          const k0 = omt * omt;
          const k1 = 2 * omt * tt;
          const k2 = tt * tt;
          mesh.position.set(
            k0 * startPos.x + k1 * ctrlPos.x + k2 * finalPos.x,
            k0 * startPos.y + k1 * ctrlPos.y + k2 * finalPos.y,
            k0 * startPos.z + k1 * ctrlPos.z + k2 * finalPos.z
          );
        }
      }, 0)
      .to(mesh.scale, {
        x: finalScale, y: finalScale, z: finalScale,
        duration: 2.0, ease: 'expo.out'
      }, 0)
      .to(mesh.material, {
        opacity: finalOpacity,
        duration: 1.2, ease: 'power2.out'
      }, 0)
      .to(halo.material, { opacity: 0.48, duration: 1.0, ease: 'power2.out' }, 0)
      .to(halo.material, { opacity: 0, duration: 1.4, ease: 'sine.inOut' }, '>-0.2')
      .to(mesh.scale, {
        x: finalScale * 1.05, y: finalScale * 1.05, z: finalScale * 1.05,
        duration: 0.7, ease: 'sine.inOut', yoyo: true, repeat: 1
      }, '>-0.1');
    }

    function makeHaloMesh(cardMesh) {
      const c = document.createElement('canvas');
      c.width = c.height = 256;
      const ctx = c.getContext('2d');
      const g = ctx.createRadialGradient(128, 128, 24, 128, 128, 128);
      g.addColorStop(0, 'rgba(255,230,195,0.72)');
      g.addColorStop(0.4, 'rgba(255,205,165,0.30)');
      g.addColorStop(1, 'rgba(255,195,155,0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, 256, 256);
      const tex = new THREE.CanvasTexture(c);
      const pose = cardMesh.userData.base;
      const geo = new THREE.PlaneGeometry(pose.w * 2.0, pose.h * 2.0);
      const mat = new THREE.MeshBasicMaterial({
        map: tex,
        transparent: true,
        opacity: 0,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      });
      const halo = new THREE.Mesh(geo, mat);
      halo.position.z = -0.02;
      return halo;
    }

    function computeYawPitchTo(worldVector) {
      const v = worldVector.clone().normalize();
      const pitch = Math.asin(Math.max(-1, Math.min(1, v.y)));
      const yaw = Math.atan2(-v.x, -v.z);
      return { yaw, pitch };
    }

    function shortestAngleDelta(from, to) {
      const TAU = Math.PI * 2;
      let d = (to - from) % TAU;
      if (d > Math.PI) d -= TAU;
      if (d < -Math.PI) d += TAU;
      return d;
    }

    function repositionLayer(layer) {
      cardMeshes.forEach(mesh => {
        if (mesh.userData.base.layer !== layer) return;
        const pose = mesh.userData.base;
        mesh.position.copy(pose.localOffset);
        mesh.lookAt(pose.lookTarget);
        if (pose.rollJitter) mesh.rotateZ(pose.rollJitter);
        mesh.userData.baseEuler.copy(mesh.rotation);
      });
    }

    // 层切换串行队列：连续两次调用不会被吞掉，第二次等第一次跑完再开始
    let _layerTransitionChain = Promise.resolve();
    function goToLayer(target) {
      const next = _layerTransitionChain.then(() => new Promise(resolve => {
        if (target < 0 || target >= TOTAL_LAYERS) { resolve(); return; }
        if (target === currentLayer) { resolve(); return; }
        const fromLayer = currentLayer;
        currentLayer = target;
        targetForward = FOCUS_DEPTHS[target] ?? FOCUS_DEPTHS[0];
        targetFov = FOV_DEFAULT + Math.min(5, targetForward * 0.12);
        hud.classList.add('soft');
        applyLayerTitleOverlay(target);
        let settled = false;
        const settle = () => { if (!settled) { settled = true; resolve(); } };
        transitionLayer(fromLayer, target, settle);
        // 兜底：gsap 异常或 onComplete 没触发时，最长 2.5s 强制结束
        setTimeout(settle, 2500);
      }));
      _layerTransitionChain = next.catch(() => {});
      return next;
    }

    function deepen() { goToLayer(currentLayer + 1); }
    function surface() { goToLayer(currentLayer - 1); }

    function resetView() {
      targetYaw = 0;
