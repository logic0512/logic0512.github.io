      { id: 'demo-18', title: '慢慢吃完一顿饭', text: '好好吃饭的时候，人会重新回到自己这里。', type: 'image', warmth: 3, date: '2025.12.29' },
      { id: 'demo-19', title: '第一口热茶', text: '握着杯子的那一刻，手先暖了，心才跟着暖。', type: 'text', warmth: 4, date: '2025.12.18' },
