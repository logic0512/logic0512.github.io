    function loadRecords() {
      try {
        const stored = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        if (Array.isArray(stored) && stored.length) {
          return SHOW_DEMO ? [...stored, ...demoRecords] : stored;
        }
      } catch {}
      return SHOW_DEMO ? demoRecords : [];
    }

    function updateEmptyState() {
      const emptyEl = document.getElementById('empty');
      const addBtn = document.getElementById('addBtn');
      const isEmpty = records.length === 0;
      emptyEl.classList.toggle('on', isEmpty);
      addBtn.classList.toggle('hidden', isEmpty);
      if (isEmpty) hud.classList.add('soft');
    }

    function saveRecords() {
      const cleaned = records
        .filter(item => !item.id.startsWith('demo-'))
        .map(item => {
          // blob: URL 是会话级，刷新即失，不存进 localStorage
          if (item.src && item.src.startsWith('blob:')) {
            return { ...item, src: '', _largeFile: true };
          }
          return item;
        });
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(cleaned));
      } catch (e) {
        // localStorage 满了（base64 太大）：去掉所有 src 再存
        const fallback = cleaned.map(item => ({ ...item, src: '', _largeFile: true }));
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(fallback)); } catch {}
      }
    }

