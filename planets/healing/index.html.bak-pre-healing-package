    const demoRecords = [
      { id: 'demo-1', title: '有人记得我怕冷', text: '那天只是很普通的一句提醒，却让我觉得自己被放在心上。', type: 'text', warmth: 5, date: '2026.05.21' },
      { id: 'demo-2', title: '晒到太阳的下午', text: '坐在窗边十分钟，心里突然安静下来。窗台上有麻雀的影子。', type: 'audio', warmth: 4, duration: 73, date: '2026.05.17' },
      { id: 'demo-3', title: '一小段路', text: '什么都没有发生，但散步回来以后，好像又能继续了。', type: 'image', warmth: 3, date: '2026.05.12' },
      { id: 'demo-4', title: '被认真听完', text: '没有建议，没有评价，只是被认真听完。', type: 'text', warmth: 5, date: '2026.05.06' },
