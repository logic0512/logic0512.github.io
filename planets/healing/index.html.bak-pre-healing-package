      { id: 'demo-12', title: '被允许休息', text: '什么都不做的那天，反而救了我。', type: 'image', warmth: 4, date: '2026.03.09' },
      { id: 'demo-13', title: '轻轻地被叫住', text: '有人说：你已经做得够好了。我突然就停下来了。', type: 'text', warmth: 4, date: '2026.02.28' },
      { id: 'demo-14', title: '不用解释', text: '那一刻，我不用解释自己为什么难过。', type: 'video', warmth: 5, date: '2026.02.13' },
