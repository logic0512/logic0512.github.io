    function createBackground() {
      const geometry = new THREE.SphereGeometry(140, 48, 24);
      SCENE_PALETTE.forEach((palette, index) => {
        const texture = new THREE.CanvasTexture(makeVoidCanvas(1024, 1024, palette));
        texture.colorSpace = THREE.SRGBColorSpace || undefined;
