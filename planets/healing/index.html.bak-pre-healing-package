<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>治愈星 · Memory Sparks</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <style>
    * { box-sizing: border-box; }
    html, body { width: 100%; height: 100%; margin: 0; overflow: hidden; }
    body {
      font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #2b2440;
      color: rgba(255, 246, 226, 0.92);
    }
    button, input, textarea { font: inherit; }
    button { cursor: pointer; border: 0; }
    #stage {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      display: block;
      touch-action: none;
    }
    .hud {
      position: fixed;
      z-index: 5;
      left: clamp(20px, 3vw, 42px);
      top: clamp(20px, 3.5vh, 42px);
      color: rgba(245, 220, 168, 0.78);
      transition: opacity 0.4s ease;
      pointer-events: none;
    }
    .hud h1 {
      margin: 0;
      font-size: 17px;
      font-weight: 300;
      letter-spacing: 0.42em;
      padding-left: 0.2em;
    }
    .hud .hint {
      margin-top: 10px;
      font-size: 11px;
      letter-spacing: 0.18em;
      color: rgba(245, 220, 168, 0.42);
      font-weight: 300;
    }
    .hud.soft { opacity: 0.36; }
    .layer-title {
      position: fixed;
      z-index: 4;
      top: clamp(78px, 11vh, 116px);
      left: 50%;
      transform: translateX(-50%);
      font-family: "SF Mono", "JetBrains Mono", "Menlo", "Courier New", monospace;
      font-weight: 300;
      font-size: 22px;
      letter-spacing: 0.58em;
      padding-left: 0.58em;
      text-transform: uppercase;
      color: rgba(80, 52, 38, 0.40);
      pointer-events: none;
      white-space: nowrap;
      opacity: 1;
      transition: opacity 0.45s ease;
    }
    .layer-title.fade-out { opacity: 0; }
    .add {
      /* 右下按钮隐藏，入口只保留右上 ms-shared FAB */
      display: none !important;
    }
    .add-orig-style-unused {
      position: fixed;
      z-index: 6;
      right: clamp(24px, 4vw, 48px);
      bottom: clamp(24px, 4.5vh, 48px);
      padding: 10px 18px 10px 14px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: transparent;
      border: 0;
      color: rgba(245, 220, 168, 0.72);
      font-size: 13px;
      letter-spacing: 0.16em;
      font-weight: 300;
      transition: color 0.25s ease, transform 0.25s ease;
    }
    .add:hover {
      color: rgba(255, 240, 200, 0.95);
      transform: translateY(-1px);
    }
    .add .plus {
      display: inline-block;
      width: 22px;
      height: 22px;
      border: 1px solid currentColor;
      border-radius: 50%;
      line-height: 20px;
      text-align: center;
      font-size: 14px;
      font-weight: 200;
    }
    .overlay {
      position: fixed;
      inset: 0;
      z-index: 8;
      opacity: 0;
      pointer-events: none;
      background: rgba(36, 26, 52, 0.22);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      transition: opacity 0.2s ease;
    }
    .overlay.on { opacity: 1; pointer-events: auto; }
    /* L1 Gentle 默认；body[data-layer="..."] 切换变量 */
    body {
      --rd-card-bg: rgba(252, 222, 200, 0.42);
      --rd-card-border: rgba(180, 110, 80, 0.22);
      --rd-card-inset: rgba(255, 250, 238, 0.6);
      --rd-card-shadow: 0 12px 40px rgba(180, 90, 60, 0.18), 0 0 60px rgba(255, 200, 175, 0.32);
      --rd-text: #5b2f1f;
      --rd-meta: rgba(91, 47, 31, 0.62);
      --rd-line: rgba(91, 47, 31, 0.22);
      --rd-accent: rgba(184, 90, 58, 0.72);
    }
    body[data-layer="companion"] {
      --rd-card-bg: rgba(250, 228, 178, 0.42);
      --rd-card-border: rgba(170, 120, 50, 0.22);
      --rd-card-inset: rgba(255, 250, 222, 0.6);
      --rd-card-shadow: 0 12px 40px rgba(170, 110, 40, 0.16), 0 0 60px rgba(245, 200, 130, 0.30);
      --rd-text: #5d3618;
      --rd-meta: rgba(93, 54, 24, 0.62);
      --rd-line: rgba(93, 54, 24, 0.22);
      --rd-accent: rgba(184, 106, 42, 0.72);
    }
    body[data-layer="inspire"] {
      --rd-card-bg: rgba(248, 232, 215, 0.42);
      --rd-card-border: rgba(160, 110, 80, 0.20);
      --rd-card-inset: rgba(255, 250, 240, 0.6);
      --rd-card-shadow: 0 12px 40px rgba(150, 100, 70, 0.14), 0 0 60px rgba(240, 215, 195, 0.28);
      --rd-text: #533622;
      --rd-meta: rgba(83, 54, 34, 0.62);
      --rd-line: rgba(83, 54, 34, 0.22);
      --rd-accent: rgba(160, 109, 58, 0.72);
    }

    .panel {
      position: fixed;
      z-index: 9;
      left: 50%;
      top: 50%;
      width: min(460px, calc(100vw - 34px));
      padding: 32px 32px 28px;
      border: 1px solid var(--rd-card-border);
      border-radius: 14px;
      background: var(--rd-card-bg);
      box-shadow: var(--rd-card-shadow), inset 0 1px 0 var(--rd-card-inset);
      backdrop-filter: blur(12px) saturate(1.08);
      -webkit-backdrop-filter: blur(12px) saturate(1.08);
      color: var(--rd-text);
      transform: translate(-50%, calc(-50% + 14px)) scale(0.985);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.28s ease, transform 0.28s ease, background 0.6s ease, border-color 0.6s ease;
    }
    .panel.open {
      opacity: 1;
      pointer-events: auto;
      transform: translate(-50%, -50%) scale(1);
    }
    .panel-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      margin-bottom: 22px;
    }
    .panel-title {
      margin: 0;
      font-size: 12px;
      font-weight: 300;
      letter-spacing: 0.32em;
      color: var(--rd-meta);
    }
    .close {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      border: 1px solid var(--rd-line);
      background: transparent;
      color: var(--rd-meta);
      font-size: 14px;
      line-height: 1;
      transition: color 0.2s ease, border-color 0.2s ease;
    }
    .close:hover {
      color: var(--rd-text);
      border-color: var(--rd-accent);
    }
    input[type="text"],
    textarea {
      width: 100%;
      border: 0;
      border-bottom: 1px solid var(--rd-line);
      background: transparent;
      outline: none;
      color: var(--rd-text);
      transition: border-color 0.2s ease;
    }
    input[type="text"]:focus,
    textarea:focus { border-bottom-color: var(--rd-accent); }
    input[type="text"] {
      height: 40px;
      margin-bottom: 18px;
      font-size: 16px;
      font-weight: 300;
      letter-spacing: 0.02em;
    }
    textarea {
      min-height: 120px;
      padding: 10px 0;
      resize: none;
      line-height: 1.85;
      font-size: 14px;
      font-weight: 300;
    }
    input::placeholder,
    textarea::placeholder {
      color: var(--rd-meta);
      opacity: 0.55;
      font-weight: 300;
    }
    .row {
      margin-top: 22px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      color: var(--rd-meta);
      font-size: 11px;
      letter-spacing: 0.14em;
    }
    .file {
      position: relative;
      display: inline-flex;
      align-items: center;
      min-height: 32px;
      max-width: 240px;
      padding: 0 2px 6px;
      border: 0;
      border-bottom: 1px solid var(--rd-line);
      background: transparent;
      color: var(--rd-meta);
      font-size: 12px;
      letter-spacing: 0.08em;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
      transition: border-color 0.2s ease, color 0.2s ease;
    }
    .file:hover {
      color: var(--rd-text);
      border-bottom-color: var(--rd-accent);
    }
    .file input {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
    }
    .warmth { display: flex; gap: 8px; }
    .warmth button {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      border: 1px solid var(--rd-line);
      background: transparent;
      color: transparent;
      font-size: 0;
      padding: 0;
      transition: background 0.2s ease, border-color 0.2s ease;
    }
    .warmth button.active {
      background: var(--rd-accent);
      border-color: var(--rd-accent);
      box-shadow: 0 0 14px var(--rd-accent);
    }
    .submit {
      width: 100%;
      min-height: 44px;
      margin-top: 26px;
      border: 1px solid var(--rd-line);
      border-radius: 2px;
      background: transparent;
      color: var(--rd-text);
      font-size: 13px;
      letter-spacing: 0.28em;
      font-weight: 300;
      transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
    }
    .submit:hover {
      background: var(--rd-card-inset);
      color: var(--rd-text);
      border-color: var(--rd-accent);
    }
    .reader-media {
      border-radius: 8px;
      overflow: hidden;
      min-height: 220px;
      margin-bottom: 22px;
      background: rgba(255, 245, 230, 0.18);
    }
    .reader-media:empty { display: none; }
    .reader-media img,
    .reader-media video {
      display: block;
      width: 100%;
      max-height: 340px;
      object-fit: cover;
    }
    .reader h2 {
      margin: 0 0 14px;
      font-family: "Noto Serif SC", "Songti SC", serif;
      font-size: 22px;
      font-weight: 500;
      letter-spacing: 0.06em;
      color: var(--rd-text);
    }
    .reader p {
      margin: 0;
      font-family: "Noto Serif SC", "Songti SC", serif;
      color: var(--rd-text);
      opacity: 0.88;
      line-height: 1.95;
      font-size: 14px;
      font-weight: 400;
    }

    /* ============ composer · 朋友圈式 ============ */
    .composer textarea { min-height: 120px; }
    .composer-media {
      border-radius: 10px;
      overflow: hidden;
      margin-top: 14px;
      margin-bottom: 6px;
      background: rgba(255, 245, 230, 0.18);
      max-height: 280px;
    }
    .composer-media:empty { display: none; }
    .composer-media img { display: block; width: 100%; max-height: 280px; object-fit: cover; }
    .composer-media video { display: block; width: 100%; max-height: 280px; }
    .composer-media audio { display: block; width: 100%; margin: 14px 0; }
    .big-file-note {
      padding: 6px 12px;
      font-size: 10px;
      letter-spacing: 0.18em;
      color: rgba(180, 100, 60, 0.78);
      background: rgba(255, 220, 195, 0.32);
      text-align: center;
    }

    .media-row {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-top: 14px;
      padding-bottom: 14px;
      border-bottom: 1px solid var(--rd-line);
    }
    .media-pick {
      width: 34px; height: 34px;
      border-radius: 8px;
      border: 1px solid var(--rd-line);
      background: transparent;
      color: var(--rd-meta);
      display: grid;
      place-items: center;
      cursor: pointer;
      transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }
    .media-pick:hover {
      color: var(--rd-text);
      border-color: var(--rd-accent);
      background: var(--rd-card-inset);
    }
    .media-pick svg { width: 18px; height: 18px; }
    .media-pick.clear {
      margin-left: auto;
      color: rgba(180, 80, 60, 0.62);
    }
    .media-pick[hidden] { display: none; }

    /* tag row · 3 标签替换情感重量 */
    .tag-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 18px;
      gap: 14px;
    }
    .tag-label {
      font-size: 11px;
      letter-spacing: 0.18em;
      color: var(--rd-meta);
    }
    .tag-group {
      display: flex;
      gap: 8px;
    }
    .tag-group button {
      padding: 6px 14px;
      border: 1px solid var(--rd-line);
      border-radius: 99px;
      background: transparent;
      color: var(--rd-meta);
      font-family: "Noto Serif SC", "Songti SC", serif;
      font-size: 12px;
      letter-spacing: 0.18em;
      padding-left: calc(14px + 0.18em);
      cursor: pointer;
      transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }
    .tag-group button:hover {
      color: var(--rd-text);
      border-color: var(--rd-accent);
    }
    .tag-group button.active {
      color: var(--rd-text);
      border-color: var(--rd-accent);
      background: var(--rd-card-inset);
    }

    /* ============ 形状 = 内容形状 · 6 套 ============ */
    .panel.reader.shape-text {
      width: min(420px, calc(100vw - 34px));
      min-height: 320px;
    }
    .panel.reader.shape-audio {
      width: min(440px, calc(100vw - 34px));
      aspect-ratio: 1 / 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .panel.reader.shape-audio .reader-media { min-height: 0; margin-bottom: 18px; background: transparent; }

    /* 图/视频：照片填满 panel，标题/正文 overlay 在底部 */
    .panel.reader.shape-image-h,
    .panel.reader.shape-image-v,
    .panel.reader.shape-video-h,
    .panel.reader.shape-video-v {
      padding: 0;
      overflow: hidden;
      /* 照片/视频盖满 panel，背后模糊看不见还耗 GPU，关掉 */
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: rgba(0, 0, 0, 0.4);
    }
    .panel.reader.shape-image-h,
    .panel.reader.shape-video-h { width: min(680px, calc(100vw - 34px)); }
    .panel.reader.shape-image-v,
    .panel.reader.shape-video-v { width: min(340px, calc(100vw - 34px)); }

    .panel.reader[class*="shape-image"] .reader-media,
    .panel.reader[class*="shape-video"] .reader-media {
      margin: 0;
      border-radius: 0;
      min-height: 0;
      background: transparent;
    }
    .panel.reader.shape-image-h .reader-media img,
    .panel.reader.shape-image-h .reader-media video { width: 100%; height: auto; max-height: none; aspect-ratio: 16/10; object-fit: cover; }
    .panel.reader.shape-image-v .reader-media img,
    .panel.reader.shape-image-v .reader-media video { width: 100%; height: auto; max-height: none; aspect-ratio: 9/16; object-fit: cover; }
    .panel.reader.shape-video-h .reader-media img,
    .panel.reader.shape-video-h .reader-media video { width: 100%; height: auto; max-height: none; aspect-ratio: 16/9; object-fit: cover; }
    .panel.reader.shape-video-v .reader-media img,
    .panel.reader.shape-video-v .reader-media video { width: 100%; height: auto; max-height: none; aspect-ratio: 9/16; object-fit: cover; }

    /* panel-head 在图/视频形态下绝对定位到右上 */
    .panel.reader[class*="shape-image"] .panel-head,
    .panel.reader[class*="shape-video"] .panel-head {
      position: absolute;
      top: 14px;
      right: 14px;
      left: auto;
      margin: 0;
      z-index: 3;
    }
    .panel.reader[class*="shape-image"] .panel-title,
    .panel.reader[class*="shape-video"] .panel-title { display: none; }
    .panel.reader[class*="shape-image"] .close,
    .panel.reader[class*="shape-video"] .close {
      background: rgba(0, 0, 0, 0.32);
      border-color: rgba(255, 247, 232, 0.42);
      color: rgba(255, 247, 232, 0.92);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    .panel.reader[class*="shape-image"] h2,
    .panel.reader[class*="shape-video"] h2 {
      position: absolute;
      left: 22px;
      right: 22px;
      bottom: 52px;
      margin: 0;
      color: #fff7e8;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.55);
      z-index: 3;
    }
    .panel.reader[class*="shape-image"] p,
    .panel.reader[class*="shape-video"] p {
      position: absolute;
      left: 22px;
      right: 22px;
      bottom: 20px;
      color: rgba(255, 247, 232, 0.88);
      text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
      font-size: 13px;
      z-index: 3;
    }
    /* 底部暗化让标题可读 */
    .panel.reader[class*="shape-image"]::after,
    .panel.reader[class*="shape-video"]::after {
      content: '';
      position: absolute;
      left: 0; right: 0; bottom: 0;
      height: 42%;
      background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.55) 100%);
      pointer-events: none;
      z-index: 2;
    }
    .empty {
      position: fixed;
      z-index: 4;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      display: none;
      flex-direction: column;
      align-items: center;
      gap: 32px;
      text-align: center;
      pointer-events: none;
    }
    .empty.on { display: flex; }
    .empty-line {
      margin: 0;
      font-size: 22px;
      font-weight: 300;
      letter-spacing: 0.32em;
      color: rgba(255, 235, 200, 0.72);
      padding-left: 0.32em;
    }
    .empty-add {
      pointer-events: auto;
      padding: 4px 0 8px;
      border: 0;
      border-bottom: 1px solid rgba(245, 200, 72, 0.5);
      background: transparent;
      color: rgba(245, 220, 168, 0.88);
      font-size: 13px;
      letter-spacing: 0.22em;
      font-weight: 300;
      transition: color 0.25s ease, border-color 0.25s ease;
    }
    .empty-add:hover {
      color: rgba(255, 248, 230, 0.98);
      border-bottom-color: rgba(255, 240, 200, 0.9);
    }
    .add.hidden { display: none; }
    .fallback {
      position: fixed;
      inset: 0;
      z-index: 20;
      display: none;
      place-items: center;
      padding: 30px;
      background: linear-gradient(135deg, #f1cfa8, #806d98);
      color: rgba(70, 45, 66, 0.82);
      text-align: center;
    }
    .fallback.on { display: grid; }
    @media (max-width: 760px) {
      .hud { width: calc(100vw - 34px); left: 17px; top: 17px; }
      .hud p { display: none; }
      .orb { width: 52px; height: 52px; }
      h1 { font-size: 24px; }
    }
