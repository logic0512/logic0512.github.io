      const testShape = params.get('testShape');
      if (testShape) setTimeout(() => openReaderTestShape(testShape), 800);
      if (params.get('openComposer')) setTimeout(() => openComposer(), 800);

      // 自动连测：?autoSeq=1 依次跨层添加 3 条
      if (params.get('autoSeq')) {
        const sequence = [
          { layer: 1, title: 'A · 陪伴' },
          { layer: 2, title: 'B · 启发' },
          { layer: 0, title: 'C · 温柔' },
        ];
        let i = 0;
        const dumpState = (tag) => {
          const layerCounts = [0, 1, 2].map(layer =>
            cardMeshes.filter(m => m.userData.base.layer === layer).length
          );
          const visibleByLayer = [0, 1, 2].map(layer =>
            cardMeshes.filter(m => m.userData.base.layer === layer && m.visible).length
          );
          window.__autoSeqLog = window.__autoSeqLog || [];
          window.__autoSeqLog.push({ tag, currentLayer, layerCounts, visibleByLayer, time: Date.now() });
        };
        const runOne = (step) => {
          if (step >= sequence.length) {
            dumpState('done');
            window.__autoSeqDone = true;
            return;
          }
          const s = sequence[step];
          dumpState(`before_${step}_layer${s.layer}`);
          openComposer();
          setTimeout(() => {
            titleInput.value = s.title;
            textInput.value = '自测条目 #' + (step + 1);
            selectedLayer = s.layer;
            document.querySelectorAll('#layerTags button').forEach(b => {
              b.classList.toggle('active', Number(b.dataset.layer) === s.layer);
            });
            setTimeout(async () => {
              await addMemory();
              setTimeout(() => {
                dumpState(`after_${step}_layer${s.layer}`);
                runOne(step + 1);
              }, 3000); // 等 flyIn 跑完
            }, 300);
          }, 200);
        };
        setTimeout(() => runOne(0), 1200);
      }
    }

