      { id: 'demo-51', title: '一起做饭', text: '切菜的声音，油锅的声音，话题的声音，混在一起。', type: 'video', warmth: 5, date: '2025.04.05' },
      { id: 'demo-52', title: '久违的拥抱', text: '比记忆里更紧一点，也更长一点。', type: 'text', warmth: 5, date: '2025.03.28' },
