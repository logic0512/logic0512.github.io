    function applyInitialLayerFromUrl() {
      const layer = Number(new URLSearchParams(location.search).get('layer'));
      if (!Number.isInteger(layer) || layer < 0 || layer >= TOTAL_LAYERS) return;
      currentLayer = layer;
      targetForward = FOCUS_DEPTHS[layer] ?? 0;
      forward = targetForward;
      targetFov = FOV_DEFAULT + Math.min(5, targetForward * 0.12);
    }

    function buildCards(newId = null) {
      cardMeshes.forEach(mesh => {
        mesh.geometry.dispose();
        mesh.material.map?.dispose();
        mesh.material.dispose();
        cardGroup.remove(mesh);
      });
      clearDecorGroup();
      sceneTitleMeshes = [];
      cardMeshes = [];
      const visualItems = expandVisualItems(records);
      let newIdSpawnAssigned = false;
      visualItems.forEach((item, index) => {
        const { record, visualId } = item;
        const slot = Number.isInteger(item.slotIndex) ? item.slotIndex : index;
        const layer = getPointForSlot(slot);
        const pose = getPose(record, Number(record.warmth || 3), slot, layer, visualId);
        const texture = new THREE.CanvasTexture(makeCardCanvas(record, pose));
        texture.anisotropy = Math.min(renderer.capabilities.getMaxAnisotropy(), 4);
        texture.colorSpace = THREE.SRGBColorSpace || undefined;
        const geometry = new THREE.PlaneGeometry(pose.w, pose.h, 1, 1);
        const material = new THREE.MeshBasicMaterial({
          map: texture,
          transparent: true,
          opacity: pose.opacity,
          side: THREE.DoubleSide,
          depthWrite: false
        });
        const mesh = new THREE.Mesh(geometry, material);
        mesh.position.copy(pose.localOffset);
        mesh.lookAt(pose.lookTarget);
        if (pose.rollJitter) mesh.rotateZ(pose.rollJitter);
        mesh.renderOrder = 10;
        const baseEuler = new THREE.Euler(mesh.rotation.x, mesh.rotation.y, mesh.rotation.z, mesh.rotation.order);
        const isSpawnTarget = record.id === newId && !newIdSpawnAssigned;
        if (isSpawnTarget) newIdSpawnAssigned = true;
        mesh.userData = {
          record,
          visualId,
          base: pose,
          baseEuler,
          targetScale: pose.scale,
          currentScale: isSpawnTarget ? 0.05 : pose.scale
        };
        // 只有第一份 newId 走 flyInNewCard 入场动画，其他副本正常出现
        if (isSpawnTarget) {
          material.opacity = 0;
          mesh.userData.spawning = true;
        }
        mesh.scale.setScalar(mesh.userData.currentScale);
        cardGroup.add(mesh);
        cardMeshes.push(mesh);
        if ((record.type === 'image' || record.type === 'video') && record.src) {
          decorateMediaMesh(mesh, record);
        }
      });
      buildSceneDecor();
      applyLayerVisibility(currentLayer, true);
      updateEmptyState();
      window.__healingDebug = {
        cards: cardMeshes.length,
        layerCounts: [0, 1, 2].map(layer => cardMeshes.filter(mesh => mesh.userData.base.layer === layer).length),
        layout: 'orbit-field-with-layer-scenes'
      };
    }

    function layerObjects(layer) {
      const objects = cardMeshes.filter(mesh => mesh.userData.base.layer === layer);
      decorGroup.children.forEach(obj => {
        if (obj.userData.layer === layer) objects.push(obj);
      });
      return objects;
    }

    function backgroundObjects(layer) {
      return bgGroup.children.filter(obj => obj.userData.layer === layer);
    }

    function setObjectOpacity(obj, opacity) {
      if (!obj.material) return;
      const materials = Array.isArray(obj.material) ? obj.material : [obj.material];
      materials.forEach(mat => {
        mat.transparent = true;
        mat.opacity = opacity;
      });
    }

    function objectBaseOpacity(obj) {
      if (typeof obj.userData.baseOpacity === 'number') return obj.userData.baseOpacity;
      if (typeof obj.userData.base?.opacity === 'number') return obj.userData.base.opacity;
      return 1;
    }

    function applyLayerVisibility(layer, immediate = false) {
      [...bgGroup.children, ...cardMeshes, ...decorGroup.children].forEach(obj => {
        // spawning 状态的卡（新增中）opacity/scale 由 flyInNewCard 接管，这里只确保 visible
        if (obj.userData.spawning) {
          obj.visible = true;
          return;
        }
        const active = obj.userData.base?.layer === layer || obj.userData.layer === layer;
        obj.visible = active;
        setObjectOpacity(obj, active ? objectBaseOpacity(obj) : 0);
        if (obj.userData.base) {
          const baseScale = obj.userData.base.scale || 1;
          obj.userData.currentScale = active || immediate ? baseScale : baseScale * 0.82;
          obj.userData.targetScale = baseScale;
          obj.scale.setScalar(obj.userData.currentScale);
        }
      });
    }

    function transitionLayer(fromLayer, toLayer, onDone) {
      isLayerAnimating = true;
      const oldBackgrounds = backgroundObjects(fromLayer);
      const newBackgrounds = backgroundObjects(toLayer);
      const oldObjects = layerObjects(fromLayer);
      const newObjects = layerObjects(toLayer);

      newBackgrounds.forEach(obj => {
        obj.visible = true;
        setObjectOpacity(obj, 0);
      });
      newObjects.forEach(obj => {
        obj.visible = true;
        setObjectOpacity(obj, 0);
        if (obj.userData.base) {
          const baseScale = obj.userData.base.scale || 1;
          obj.userData.currentScale = baseScale * 0.82;
          obj.userData.targetScale = baseScale;
          obj.scale.setScalar(obj.userData.currentScale);
        }
      });

      if (typeof gsap === 'undefined') {
        oldBackgrounds.forEach(obj => { obj.visible = false; setObjectOpacity(obj, 0); });
        newBackgrounds.forEach(obj => { obj.visible = true; setObjectOpacity(obj, objectBaseOpacity(obj)); });
        oldObjects.forEach(obj => { obj.visible = false; setObjectOpacity(obj, 0); });
        newObjects.forEach(obj => setObjectOpacity(obj, objectBaseOpacity(obj)));
        isLayerAnimating = false;
        onDone?.();
        return;
      }

      const tl = gsap.timeline({
        onComplete: () => {
          oldBackgrounds.forEach(obj => { obj.visible = false; setObjectOpacity(obj, 0); });
          newBackgrounds.forEach(obj => { obj.visible = true; setObjectOpacity(obj, objectBaseOpacity(obj)); });
          oldObjects.forEach(obj => { obj.visible = false; setObjectOpacity(obj, 0); });
          newObjects.forEach(obj => {
            obj.visible = true;
            setObjectOpacity(obj, objectBaseOpacity(obj));
            if (obj.userData.base) {
              const baseScale = obj.userData.base.scale || 1;
              obj.userData.currentScale = baseScale;
              obj.userData.targetScale = baseScale;
              obj.scale.setScalar(baseScale);
            }
          });
          isLayerAnimating = false;
          onDone?.();
        }
      });

      oldBackgrounds.forEach(obj => {
        const materials = Array.isArray(obj.material) ? obj.material : [obj.material].filter(Boolean);
        materials.forEach(mat => tl.to(mat, { opacity: 0, duration: 0.95, ease: 'sine.inOut' }, 0));
      });
      newBackgrounds.forEach(obj => {
        const materials = Array.isArray(obj.material) ? obj.material : [obj.material].filter(Boolean);
        materials.forEach(mat => tl.to(mat, { opacity: objectBaseOpacity(obj), duration: 0.95, ease: 'sine.inOut' }, 0));
      });
      oldObjects.forEach(obj => {
        const materials = Array.isArray(obj.material) ? obj.material : [obj.material].filter(Boolean);
        materials.forEach(mat => tl.to(mat, { opacity: 0, duration: 0.42, ease: 'sine.out' }, 0.08));
      });
      newObjects.forEach(obj => {
        const materials = Array.isArray(obj.material) ? obj.material : [obj.material].filter(Boolean);
        materials.forEach(mat => tl.to(mat, { opacity: objectBaseOpacity(obj), duration: 0.9, ease: 'sine.out' }, 0.62));
        if (obj.userData.base) {
          const baseScale = obj.userData.base.scale || 1;
          tl.to(obj.scale, { x: baseScale, y: baseScale, z: baseScale, duration: 1.0, ease: 'power2.out' }, 0.62);
        }
      });
    }

    function getRecordLayer(record) {
      if (Number.isInteger(record.layer) && record.layer >= 0 && record.layer < TOTAL_LAYERS) return record.layer;
      const w = Math.max(1, Math.min(5, Number(record.warmth) || 3));
      if (w >= 5) return 2;
      if (w >= 4) return 1;
      return 0;
    }

    function expandVisualItems(sourceRecords) {
      if (!sourceRecords.length) return [];
      const layerBuckets = [[], [], []];
      sourceRecords.forEach(record => {
        const layer = getRecordLayer(record);
        layerBuckets[layer].push(record);
      });
      const items = [];
      layerBuckets.forEach((bucket, layer) => {
        if (!bucket.length) return;
        const copies = bucket.length >= 30 ? 1 : bucket.length >= 15 ? 2 : 3;
        const layerStart = layer * CARDS_PER_POINT;
        let slotInLayer = 0;
        bucket.forEach((record, idx) => {
          for (let c = 0; c < copies; c++) {
            if (slotInLayer >= CARDS_PER_POINT) break;
            items.push({
              record,
              visualId: `${record.id}:v${c}:${slotInLayer}`,
              slotIndex: layerStart + slotInLayer,
            });
            slotInLayer++;
          }
        });
      });
      return items;
    }

    const LAYER_TITLES = ['GENTLE', 'COMPANION', 'INSPIRE'];

    function clearDecorGroup() {
      if (!decorGroup) return;
      decorGroup.traverse(obj => {
        obj.geometry?.dispose?.();
        if (Array.isArray(obj.material)) obj.material.forEach(mat => mat.dispose?.());
        else obj.material?.dispose?.();
        obj.material?.map?.dispose?.();
      });
      decorGroup.clear();
    }

    function buildSceneDecor() {
      createSceneTitles();
      createGentleLightPanes();
      createCompanionThreads();
      createInspirationTrails();
    }

    function createSceneTitles() {
      // 标题改用 HTML overlay（在 #layerTitle），不再创建 3D plane
      // 3D plane 即使 depthTest:false 也会被 transparent 卡片的 alpha 稀释
      applyLayerTitleOverlay(currentLayer);
    }

    function applyLayerTitleOverlay(layerIndex) {
      const paletteName = (SCENE_PALETTE[layerIndex] && SCENE_PALETTE[layerIndex].name) || 'gentle';
      document.body.dataset.layer = paletteName;
      const el = document.getElementById('layerTitle');
      if (!el) return;
      const target = LAYER_TITLES[layerIndex] || '';
      if (el.dataset.text === target) return;
      el.classList.add('fade-out');
      setTimeout(() => {
        el.textContent = target;
        el.dataset.text = target;
        el.classList.remove('fade-out');
      }, 260);
    }

    function makeTitleCanvas(title, palette, index) {
      const c = document.createElement('canvas');
      c.width = 1280;
      c.height = 280;
      const ctx = c.getContext('2d');
      ctx.clearRect(0, 0, c.width, c.height);

      ctx.fillStyle = palette.title.replace(/[\d.]+\)$/, '0.55)');
      ctx.font = '300 64px "SF Mono", "JetBrains Mono", "Menlo", "Courier New", monospace';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      const spacedTitle = [...title].join('  ');
      ctx.fillText(spacedTitle, c.width / 2, c.height / 2);
      return c;
    }

    function drawSpacedText(ctx, text, x, y, spacing) {
      let cursor = x;
      [...text].forEach(char => {
        ctx.fillText(char, cursor, y);
        cursor += ctx.measureText(char).width + spacing;
      });
    }

    function createGentleLightPanes() {
      const material = new THREE.MeshBasicMaterial({
        color: 0xfff4e8,
        transparent: true,
        opacity: 0.16,
        depthTest: false,
        depthWrite: false,
        side: THREE.DoubleSide
      });
      for (let i = 0; i < 7; i++) {
        const mesh = new THREE.Mesh(new THREE.PlaneGeometry(3.4 + i * 0.12, 1.5), material.clone());
        mesh.position.set((i - 3) * 1.55, 1.7 + (i % 2) * 0.9, -4.5 - i * 1.2);
        mesh.rotation.set(0.12, -0.36 + i * 0.12, 0.05);
        mesh.renderOrder = 2;
        mesh.userData.layer = 0;
        mesh.userData.baseOpacity = 0.16;
        decorGroup.add(mesh);
      }
    }

    function createCompanionThreads() {
      const meshes = cardMeshes.filter(mesh => mesh.userData.base.layer === 1);
      const points = [];
      for (let i = 0; i < meshes.length - 1; i += 5) {
        const a = meshes[i].position;
        const b = meshes[(i + 3) % meshes.length].position;
        if (a.distanceTo(b) > 7.8) continue;
        points.push(a.x, a.y, a.z, b.x, b.y, b.z);
      }
      if (!points.length) return;
      const geometry = new THREE.BufferGeometry();
      geometry.setAttribute('position', new THREE.Float32BufferAttribute(points, 3));
      const material = new THREE.LineBasicMaterial({
        color: 0xfff0cf,
        transparent: true,
        opacity: 0.20,
        depthTest: false,
        depthWrite: false
      });
      const line = new THREE.LineSegments(geometry, material);
      line.renderOrder = 3;
      line.userData.layer = 1;
      line.userData.baseOpacity = 0.20;
      decorGroup.add(line);
    }

    function createInspirationTrails() {
      const centerZ = -2 * POINT_GAP;
      const material = new THREE.LineBasicMaterial({
        color: 0xffead8,
        transparent: true,
        opacity: 0.20,
        depthTest: false,
        depthWrite: false
      });
      for (let i = 0; i < 6; i++) {
        const side = i % 2 ? -1 : 1;
        const y = -1.9 + i * 0.72;
        const curve = new THREE.CatmullRomCurve3([
          new THREE.Vector3(side * 5.2, y, centerZ + 5.2),
          new THREE.Vector3(side * 2.2, y * 0.42, centerZ - 1.4),
          new THREE.Vector3(side * 0.9, y * 0.18, centerZ - 8.4),
          new THREE.Vector3(side * 3.2, y * 0.08, centerZ - 15.8)
        ]);
        const geometry = new THREE.BufferGeometry().setFromPoints(curve.getPoints(36));
        const line = new THREE.Line(geometry, material.clone());
        line.renderOrder = 3;
        line.userData.layer = 2;
        line.userData.baseOpacity = 0.20;
        decorGroup.add(line);
      }
    }

    const CARD_SIZE = 1.32;
    const FIELD_DEPTH = 72;
    const FORWARD_MAX = 56;
    const TOTAL_LAYERS = 3;
    const FOCUS_DEPTHS = [0, 28, 56];
    const POINT_GAP = 28;
    const CARDS_PER_POINT = 72;
    const ORBIT_RINGS = [
      { radius: 8.7, pitch: -0.02, scale: 1.00, count: 18 },
      { radius: 9.7, pitch: 0.34, scale: 0.82, count: 18 },
      { radius: 9.7, pitch: -0.34, scale: 0.82, count: 18 },
      { radius: 11.4, pitch: 0.10, scale: 0.62, count: 18 }
    ];
    const layerCenters = [
      new THREE.Vector3(0, 0, 0),
      new THREE.Vector3(0, 0, 0),
      new THREE.Vector3(0, 0, 0)
    ];

    function getLayerForWarmth(w) {
      const wn = Math.max(1, Math.min(5, Number(w) || 3));
      if (wn >= 5) return 2;
      if (wn === 4) return 1;
      return 0;
    }

    // 卡片形状 = 内容形状（含异步测量缓存）
    const SHAPE_DIM = {
      'image-h': { w: 1.18, h: 0.74 }, // 16/10
      'image-v': { w: 0.66, h: 1.18 }, // 9/16
      'video-h': { w: 1.20, h: 0.68 }, // 16/9
      'video-v': { w: 0.66, h: 1.18 }, // 9/16
      'audio':   { w: 0.95, h: 0.95 }, // 1/1
      'text':    { w: 0.80, h: 1.12 }, // 5/7
    };
    const aspectCache = new Map(); // id → 'h' | 'v'
    const aspectInflight = new Set();

    function getRecordShape(record) {
      if (!record) return 'text';
      if (record.type === 'text') return 'text';
      if (record.type === 'audio') return 'audio';
      if (record.type === 'image' || record.type === 'video') {
        const cached = aspectCache.get(record.id);
        if (cached) return `${record.type}-${cached}`;
        // 未测量：先返回横向默认；如果有 src 异步测一下
        if (record.src && !aspectInflight.has(record.id)) {
          aspectInflight.add(record.id);
          measureAspect(record).then(asp => {
            aspectInflight.delete(record.id);
            if (!asp) return;
            const prev = aspectCache.get(record.id);
            aspectCache.set(record.id, asp);
            if (prev !== asp) buildCards();
          });
        }
        return `${record.type}-h`;
      }
      return 'text';
    }

    function measureAspect(record) {
      return new Promise(resolve => {
        if (!record.src) return resolve(null);
        if (record.type === 'image') {
          const img = new Image();
          img.onload = () => resolve(img.naturalWidth >= img.naturalHeight ? 'h' : 'v');
          img.onerror = () => resolve(null);
          img.src = record.src;
        } else if (record.type === 'video') {
          const v = document.createElement('video');
          v.preload = 'metadata';
          v.muted = true;
          v.onloadedmetadata = () => resolve(v.videoWidth >= v.videoHeight ? 'h' : 'v');
          v.onerror = () => resolve(null);
          v.src = record.src;
        } else {
          resolve(null);
        }
      });
    }

    function hashId(s) {
      const str = String(s || 'x');
      let h = 5381;
      for (let i = 0; i < str.length; i++) {
        h = ((h * 33) ^ str.charCodeAt(i)) | 0;
      }
      return Math.abs(h) + 1;
    }

    function getPointForSlot(slot) {
      return Math.min(TOTAL_LAYERS - 1, Math.floor(slot / CARDS_PER_POINT));
    }

    function getPose(record, warmth, slot, layer, visualId = record.id) {
      const idHash = hashId(visualId);
      const point = getPointForSlot(slot);
      const local = slot % CARDS_PER_POINT;
      const ringIndex = Math.floor(local / 18);
      const ringSlot = local % 18;
      const ring = ORBIT_RINGS[ringIndex] || ORBIT_RINGS[0];
      const centerZ = -point * POINT_GAP;
      const yawStep = (Math.PI * 2) / ring.count;
      const yawJitter = (seeded(idHash + 31) - 0.5) * 0.24;
      const theta = ringSlot * yawStep + ringIndex * 0.31 + point * 0.23 + yawJitter;
      const pitch = ring.pitch + (seeded(idHash + 32) - 0.5) * 0.16;
      const radius = ring.radius + (seeded(idHash + 33) - 0.5) * 1.1;
      const horizontal = Math.cos(pitch) * radius;
      const x = Math.sin(theta) * horizontal * 1.12;
      const y = Math.sin(pitch) * radius * 0.94;
      const z = centerZ - Math.cos(theta) * horizontal;
      const localOffset = new THREE.Vector3(x, y, z);
      const lookTarget = new THREE.Vector3(x * 0.10, y * 0.10, centerZ);

      const shape = getRecordShape(record);
      const dim = SHAPE_DIM[shape] || SHAPE_DIM['text'];
      const isPortrait = dim.h > dim.w;
      const warmthScale = 0.92 + Math.min(5, Math.max(1, warmth)) * 0.032;
      const anchorScale = ringSlot % 6 === 0 ? 1.18 : 0.92;
      const sizeMul = ring.scale * anchorScale * warmthScale * (0.92 + seeded(idHash + 17) * 0.15);
      const w = CARD_SIZE * sizeMul * dim.w;
      const h = CARD_SIZE * sizeMul * dim.h;

      return {
        localOffset,
        lookTarget,
        w, h,
        layer,
        shape,
        isPortrait,
        scale: layer === 1 ? 1.04 : 1,
        rollJitter: (seeded(idHash + 6) - 0.5) * 0.13,
        opacity: 0.94,
        breathSeed: (idHash % 9973) * 0.013
      };
    }

    function recordAspect(index) {
      return [0, 4, 7, 12, 15].includes(index % 18) ? 'portrait' : 'landscape';
    }

    function seeded(n) {
      const x = Math.sin(n * 999.91) * 10000;
      return x - Math.floor(x);
    }

    function makeCardCanvas(record, pose) {
      const shape = pose?.shape || getRecordShape(record);
      const dim = SHAPE_DIM[shape] || SHAPE_DIM['text'];
      const aspect = dim.h / dim.w; // h/w ratio
      const baseW = 520;
      const w = baseW;
      const h = Math.round(baseW * aspect);
      const c = document.createElement('canvas');
      c.width = w;
      c.height = h;
      const ctx = c.getContext('2d');

      drawGlassBase(ctx, w, h);

      const type = record.type || 'text';
      if (type === 'image' || type === 'video') {
        drawMediaPlaceholder(ctx, w, h, record);
        drawCardMeta(ctx, w, h, record, type);
        if (type === 'video') drawVideoCorner(ctx, w, h);
      } else if (type === 'audio') {
        drawAudioContent(ctx, w, h, record);
        drawCardMeta(ctx, w, h, record, type);
      } else {
        drawTextContent(ctx, w, h, record);
      }

      drawGlassEdge(ctx, w, h);
      return c;
    }

    function drawGlassBase(ctx, w, h) {
      ctx.save();
      ctx.beginPath();
      roundRect(ctx, 0, 0, w, h, 14);
      ctx.clip();

      ctx.fillStyle = 'rgba(255, 252, 246, 0.22)';
      ctx.fillRect(0, 0, w, h);

      const highlight = ctx.createLinearGradient(0, 0, 0, h);
      highlight.addColorStop(0, 'rgba(255, 255, 255, 0.45)');
      highlight.addColorStop(0.18, 'rgba(255, 255, 255, 0.08)');
      highlight.addColorStop(1, 'rgba(255, 255, 255, 0)');
      ctx.fillStyle = highlight;
      ctx.fillRect(0, 0, w, h);

      const shadow = ctx.createLinearGradient(0, h * 0.65, 0, h);
      shadow.addColorStop(0, 'rgba(60, 38, 24, 0)');
      shadow.addColorStop(1, 'rgba(60, 38, 24, 0.12)');
      ctx.fillStyle = shadow;
      ctx.fillRect(0, h * 0.65, w, h * 0.35);

      ctx.restore();
    }

    function drawGlassEdge(ctx, w, h) {
      ctx.save();
      ctx.strokeStyle = 'rgba(255, 252, 246, 0.55)';
      ctx.lineWidth = 1.4;
      roundRect(ctx, 0.7, 0.7, w - 1.4, h - 1.4, 14);
      ctx.stroke();
      ctx.restore();
    }

    function drawMediaPlaceholder(ctx, w, h, record) {
      const dx = 18, dy = 18;
      const dw = w - 36;
      const dh = h - 108;
      ctx.save();
      ctx.beginPath();
      roundRect(ctx, dx, dy, dw, dh, 8);
      ctx.clip();
      const g = ctx.createLinearGradient(dx, dy, dx + dw, dy + dh);
      g.addColorStop(0, 'rgba(255, 232, 200, 0.42)');
      g.addColorStop(1, 'rgba(180, 140, 110, 0.38)');
      ctx.fillStyle = g;
      ctx.fillRect(dx, dy, dw, dh);
      ctx.fillStyle = 'rgba(80, 52, 38, 0.36)';
      ctx.font = '300 42px "PingFang SC", sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(record.type === 'video' ? '▶' : '◯', dx + dw / 2, dy + dh / 2);
      ctx.textAlign = 'left';
      ctx.textBaseline = 'alphabetic';
      ctx.restore();
    }

    function drawAudioContent(ctx, w, h, record) {
      const cx = w / 2;
      const cy = (h - 88) / 2 + 6;
      const margin = 50;
      const bars = 28;
      const spacing = (w - margin * 2) / bars;
      const seed = (record.id ? record.id.length : 7) + Number(record.warmth || 3);
      ctx.save();
      for (let i = 0; i < bars; i++) {
        const phase = (i + seed) * 0.42;
        const amp = Math.sin(phase) * 0.55 + Math.sin(phase * 1.6) * 0.30 + Math.sin(phase * 0.73) * 0.32;
        const barH = 26 + Math.abs(amp) * (h * 0.32);
        const x = margin + i * spacing;
        const grad = ctx.createLinearGradient(x, cy - barH / 2, x, cy + barH / 2);
        grad.addColorStop(0, 'rgba(80, 52, 38, 0.66)');
        grad.addColorStop(1, 'rgba(80, 52, 38, 0.30)');
        ctx.fillStyle = grad;
        ctx.beginPath();
        roundRect(ctx, x, cy - barH / 2, Math.max(3, spacing - 4), barH, 3);
        ctx.fill();
      }
      ctx.restore();
    }

    function drawTextContent(ctx, w, h, record) {
      ctx.save();
      ctx.fillStyle = 'rgba(80, 52, 38, 0.32)';
      ctx.font = 'italic 400 110px "EB Garamond", "Cormorant Garamond", "Georgia", serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'alphabetic';
      ctx.fillText('“', w / 2, h * 0.30);

      ctx.fillStyle = 'rgba(60, 38, 24, 0.88)';
      ctx.font = '300 28px "PingFang SC", -apple-system, sans-serif';
      ctx.textBaseline = 'middle';
      const titleLines = wrapTextLines(ctx, record.title || '', w - 60, 2);
      const titleLineH = 38;
      let cursorY = h * 0.42;
      titleLines.forEach((line, i) => {
        ctx.fillText(line, w / 2, cursorY + i * titleLineH);
      });
      cursorY += (titleLines.length - 0.5) * titleLineH + 18;

      if (record.text) {
        ctx.fillStyle = 'rgba(60, 38, 24, 0.56)';
        ctx.font = '300 16px "PingFang SC", -apple-system, sans-serif';
        const excerptLines = wrapTextLines(ctx, record.text, w - 80, 3);
        const excerptLineH = 26;
        excerptLines.forEach((line, i) => {
          ctx.fillText(line, w / 2, cursorY + i * excerptLineH);
        });
      }
      ctx.textAlign = 'left';
      ctx.textBaseline = 'alphabetic';
      ctx.restore();
    }

    function drawCardMeta(ctx, w, h, record, type) {
      ctx.save();
      ctx.fillStyle = 'rgba(60, 38, 24, 0.86)';
      ctx.font = '400 22px "PingFang SC", -apple-system, sans-serif';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'alphabetic';
      const title = (record.title || '').trim();
      const titleLine = title.length > 14 ? title.slice(0, 13) + '…' : title;
      ctx.fillText(titleLine, 22, h - 40);

      let metaText = type.toUpperCase();
      if (type === 'audio' && record.duration) {
        metaText = `AUDIO · ${formatDuration(record.duration)}`;
      }
      ctx.fillStyle = 'rgba(60, 38, 24, 0.48)';
      ctx.font = '300 12px "SF Mono", "Menlo", monospace';
      ctx.fillText(metaText, 22, h - 18);
      ctx.restore();
    }

    function drawVideoCorner(ctx, w, h) {
      const cx = w - 42, cy = h - 124;
      ctx.save();
      ctx.fillStyle = 'rgba(40, 24, 16, 0.42)';
      ctx.beginPath();
      ctx.arc(cx, cy, 16, 0, Math.PI * 2);
      ctx.fill();
      ctx.strokeStyle = 'rgba(255, 250, 240, 0.78)';
      ctx.lineWidth = 1.2;
      ctx.stroke();
      ctx.fillStyle = 'rgba(255, 250, 240, 0.95)';
      ctx.beginPath();
      ctx.moveTo(cx - 4, cy - 6);
      ctx.lineTo(cx + 7, cy);
      ctx.lineTo(cx - 4, cy + 6);
      ctx.closePath();
      ctx.fill();
      ctx.restore();
    }

    function drawCoverImage(ctx, source, dx, dy, dw, dh) {
      const sw = source.videoWidth || source.naturalWidth || source.width;
      const sh = source.videoHeight || source.naturalHeight || source.height;
      if (!sw || !sh) return;
      const destRatio = dw / dh;
      const srcRatio = sw / sh;
      let sx, sy, ssw, ssh;
      if (srcRatio > destRatio) {
        ssh = sh;
        ssw = sh * destRatio;
        sx = (sw - ssw) / 2;
        sy = 0;
      } else {
        ssw = sw;
        ssh = sw / destRatio;
        sx = 0;
        sy = (sh - ssh) / 2;
      }
      ctx.save();
      ctx.beginPath();
      roundRect(ctx, dx, dy, dw, dh, 6);
      ctx.clip();
      ctx.drawImage(source, sx, sy, ssw, ssh, dx, dy, dw, dh);
      ctx.restore();
    }

    function formatDuration(seconds) {
      const total = Math.max(0, Math.round(Number(seconds) || 0));
      const m = Math.floor(total / 60);
      const s = total % 60;
      return `${m}:${String(s).padStart(2, '0')}`;
    }

    function wrapTextLines(ctx, text, maxWidth, maxLines) {
      const chars = [...String(text)];
      const lines = [];
      let line = '';
      for (const ch of chars) {
        const test = line + ch;
        if (ctx.measureText(test).width > maxWidth && line) {
          lines.push(line);
          line = ch;
          if (lines.length >= maxLines) break;
        } else {
          line = test;
        }
      }
      if (line && lines.length < maxLines) lines.push(line);
      return lines;
    }

    function decorateMediaMesh(mesh, record) {
      if (!record.src) return;
      if (record.type === 'video') {
        const video = document.createElement('video');
        // blob: URL 不需要 crossOrigin；http(s) 远程才需要
        if (!record.src.startsWith('blob:')) video.crossOrigin = 'anonymous';
        video.muted = true;
        video.playsInline = true;
        video.preload = 'auto';
        let drawn = false;
        const tryDraw = () => {
          if (drawn) return;
          // 视频维度准备好才能 drawImage
          if (!video.videoWidth || !video.videoHeight) return;
          drawn = true;
          redrawMeshWithSource(mesh, record, video);
        };
        video.addEventListener('loadeddata', () => {
          try {
            video.currentTime = Math.min(0.6, (video.duration || 1) / 4);
          } catch {
            tryDraw();
          }
        }, { once: true });
        video.addEventListener('seeked', tryDraw, { once: true });
        // 兜底：3 秒还没 seeked 就用当前帧
        setTimeout(tryDraw, 3000);
        video.addEventListener('error', () => {}, { once: true });
        video.src = record.src;
        video.load();
        return;
      }
      const img = new Image();
      img.onload = () => redrawMeshWithSource(mesh, record, img);
      img.onerror = () => {};
      img.src = record.src;
    }

    function redrawMeshWithSource(mesh, record, source) {
      const map = mesh.material.map;
      const canvas = map?.image;
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      const w = canvas.width;
      const h = canvas.height;
      ctx.clearRect(0, 0, w, h);
      drawGlassBase(ctx, w, h);
      drawCoverImage(ctx, source, 18, 18, w - 36, h - 108);
      drawCardMeta(ctx, w, h, record, record.type || 'image');
      if (record.type === 'video') drawVideoCorner(ctx, w, h);
      drawGlassEdge(ctx, w, h);
      map.needsUpdate = true;
    }

    function roundRect(ctx, x, y, w, h, r) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + w, y, x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x, y + h, r);
      ctx.arcTo(x, y + h, x, y, r);
      ctx.arcTo(x, y, x + w, y, r);
      ctx.closePath();
    }

    function wrapText(ctx, text, x, y, maxWidth, lineHeight, maxLines) {
      const chars = [...String(text)];
      let line = '';
      let lines = 0;
      for (const ch of chars) {
        const test = line + ch;
        if (ctx.measureText(test).width > maxWidth && line) {
          ctx.fillText(line, x, y + lines * lineHeight);
          line = ch;
          lines++;
          if (lines >= maxLines) return;
        } else {
          line = test;
        }
      }
      if (line && lines < maxLines) ctx.fillText(line, x, y + lines * lineHeight);
    }

    function bindEvents() {
      window.addEventListener('resize', resize);
      canvas.addEventListener('pointerdown', onPointerDown);
      canvas.addEventListener('pointermove', onPointerMove);
      canvas.addEventListener('pointerup', onPointerUp);
      canvas.addEventListener('pointerleave', onPointerUp);
      canvas.addEventListener('click', onClick);
      canvas.addEventListener('wheel', onWheel, { passive: false });
      document.getElementById('addBtn').addEventListener('click', () => openComposer());
      document.getElementById('emptyAdd').addEventListener('click', () => openComposer());
      document.getElementById('closeComposer').addEventListener('click', closeComposer);
      document.getElementById('closeReader').addEventListener('click', closeReader);
      overlay.addEventListener('click', () => { closeComposer(); closeReader(); });
      document.getElementById('layerTags').addEventListener('click', event => {
        const btn = event.target.closest('button[data-layer]');
        if (!btn) return;
        selectedLayer = Number(btn.dataset.layer);
        document.querySelectorAll('#layerTags button').forEach(b => b.classList.toggle('active', b === btn));
      });
      // 媒体选择：3 个 file input，每个对应一种 kind
      document.querySelectorAll('#mediaRow input[type="file"]').forEach(input => {
        input.addEventListener('change', async () => {
          const file = input.files?.[0];
          if (!file) return;
          const kind = input.dataset.kind;
          const { url, persistent } = await readFileAsDataUrl(file);
          if (!url) return;
          attachedKind = kind;
          attachedDataUrl = url;
          attachedFileName = file.name;
          attachedPersistent = persistent;
          renderAttachedPreview();
          // 清空其它两个 file input，避免冲突
          document.querySelectorAll('#mediaRow input[type="file"]').forEach(i => {
            if (i !== input) i.value = '';
          });
        });
      });
      document.getElementById('clearMedia').addEventListener('click', clearAttached);
      document.getElementById('submitMemory').addEventListener('click', addMemory);
      window.addEventListener('keydown', event => {
        if (event.key === 'Escape') { closeComposer(); closeReader(); }
        if ((event.metaKey || event.ctrlKey) && event.key === 'Enter' && composer.classList.contains('open')) addMemory();
        if (event.code === 'Space' || event.key === ' ') {
          const tag = document.activeElement?.tagName;
          if (tag === 'INPUT' || tag === 'TEXTAREA') return;
          if (composer.classList.contains('open') || reader.classList.contains('open')) return;
          event.preventDefault();
          resetView();
        }
        if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
          const tag = document.activeElement?.tagName;
          if (tag === 'INPUT' || tag === 'TEXTAREA') return;
          if (composer.classList.contains('open') || reader.classList.contains('open')) return;
          event.preventDefault();
          if (event.key === 'ArrowUp') deepen();
          else surface();
        }
      });
    }

    function resize() {
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.0));
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
    }

    function onPointerDown(event) {
      dragging = true;
      dragStart = { x: event.clientX, y: event.clientY, yaw: targetYaw, pitch: targetPitch, time: performance.now() };
      lastPointer = { x: event.clientX, y: event.clientY, time: performance.now() };
      velocityYaw = 0;
      velocityPitch = 0;
      canvas.setPointerCapture(event.pointerId);
      hud.classList.add('soft');
    }

    function onPointerMove(event) {
      updatePointer(event);
      if (dragging) {
        const now = performance.now();
        const dx = event.clientX - (lastPointer?.x ?? event.clientX);
        const dy = event.clientY - (lastPointer?.y ?? event.clientY);
        const dt = Math.max(1, now - (lastPointer?.time ?? now));
        const yawPerPx = (Math.PI * 1.4) / window.innerWidth;
        const pitchPerPx = (Math.PI * 0.9) / window.innerHeight;
        targetYaw -= dx * yawPerPx;
        targetPitch -= dy * pitchPerPx;
        targetPitch = Math.max(-PITCH_LIMIT, Math.min(PITCH_LIMIT, targetPitch));
        velocityYaw = -dx * yawPerPx / dt * 16;
        velocityPitch = -dy * pitchPerPx / dt * 16;
        lastPointer = { x: event.clientX, y: event.clientY, time: now };
      }
    }

    function onPointerUp(event) {
      dragging = false;
      try { canvas.releasePointerCapture(event.pointerId); } catch {}
    }

    function onWheel(event) {
      event.preventDefault();
      if (event.deltaY < 0) deepen();
      else if (event.deltaY > 0) surface();
      hud.classList.add('soft');
    }

    function updatePointer(event) {
      pointer.x = (event.clientX / window.innerWidth) * 2 - 1;
      pointer.y = -(event.clientY / window.innerHeight) * 2 + 1;
    }

    function onClick(event) {
      if (dragStart && Math.abs(event.clientX - dragStart.x) + Math.abs(event.clientY - dragStart.y) > 8) return;
      updatePointer(event);
      raycaster.setFromCamera(pointer, camera);
      const hits = raycaster.intersectObjects(cardMeshes, false);
      if (hits[0]) openReader(hits[0].object.userData.record.id);
    }

    // 渲染节流：场景闲置时降到 ~30fps，popup 打开时几乎完全停（让出 CPU/GPU 给视频解码 + backdrop-filter）
    let _frameTick = 0;
    let _lastPointerX = -1, _lastPointerY = -1;
    function animate() {
      requestAnimationFrame(animate);
      _frameTick++;
      const t = performance.now() * 0.001;

      // popup 打开时：场景只渲染极低速（每 12 帧一次 ≈ 5fps），把 CPU 让给视频/backdrop-filter
      const popupOpen = (composer.classList.contains('open')) || (reader.classList.contains('open'));
      if (popupOpen && (_frameTick % 12) !== 0) {
        return;
      }

      // 检测"是否有运动" — 没有就直接 return 跳过本帧
      const camMoving =
        dragging ||
        Math.abs(velocityYaw) > 0.0002 ||
        Math.abs(velocityPitch) > 0.0002 ||
        Math.abs(targetYaw - yaw) > 0.001 ||
        Math.abs(targetPitch - pitch) > 0.001 ||
        Math.abs(targetForward - forward) > 0.05 ||
        Math.abs(-forward - camera.position.z) > 0.05 ||
        Math.abs(camera.fov - targetFov) > 0.05;
      const sceneMoving = isLayerAnimating || cardMeshes.some(m => m.userData.spawning);
      const pointerMoved = pointer.x !== _lastPointerX || pointer.y !== _lastPointerY;

      // 闲置：每 2 帧渲染一次，节省 50% GPU
      if (!camMoving && !sceneMoving && !pointerMoved && !popupOpen && (_frameTick & 1)) {
        return;
      }
      _lastPointerX = pointer.x;
      _lastPointerY = pointer.y;

      if (!dragging && (Math.abs(velocityYaw) > 0.0002 || Math.abs(velocityPitch) > 0.0002)) {
        targetYaw += velocityYaw;
        targetPitch = Math.max(-PITCH_LIMIT, Math.min(PITCH_LIMIT, targetPitch + velocityPitch));
        velocityYaw *= 0.93;
        velocityPitch *= 0.93;
      }
      yaw += (targetYaw - yaw) * 0.10;
      pitch += (targetPitch - pitch) * 0.10;
      forward += (targetForward - forward) * 0.085;
      camera.position.x += (0 - camera.position.x) * 0.08;
      camera.position.y += (0 - camera.position.y) * 0.08;
      camera.position.z += (-forward - camera.position.z) * 0.08;
      camera.rotation.order = 'YXZ';
      camera.rotation.y = yaw;
      camera.rotation.x = pitch;
      camera.rotation.z = 0;
      if (Math.abs(camera.fov - targetFov) > 0.05) {
        camera.fov += (targetFov - camera.fov) * 0.12;
        camera.updateProjectionMatrix();
      }
      cardGroup.position.x = Math.sin(t * 0.08) * 0.06;
      cardGroup.position.y = Math.sin(t * 0.06) * 0.05;
      particleGroup.position.z += (-forward * 0.18 - particleGroup.position.z) * 0.05;
      if (bgGroup) {
        bgGroup.children.forEach((mesh, index) => {
          if (!mesh.visible) return;
          mesh.position.copy(camera.position);
          mesh.rotation.y = t * (0.003 + index * 0.0015);
        });
        scene.fog.color.lerp(SCENE_FOG_COLORS[currentLayer], 0.035);
      }
      updateHoverScale();
      renderer.render(scene, camera);
      canvas.dataset.rendered = '1';
    }

    function updateHoverScale() {
      // raycast 每 3 帧一次：人眼感知不到 hover 延迟，节省 2/3 raycast 成本
      if ((_frameTick % 3) === 0) {
        // 只 raycast 当前层的可见卡片（隐藏层的卡片不参与命中）
        const visibleCards = cardMeshes.filter(m => m.visible && !m.userData.spawning);
        raycaster.setFromCamera(pointer, camera);
        const hits = raycaster.intersectObjects(visibleCards, false);
        const nextHover = hits[0]?.object || null;
        if (nextHover !== hoverMesh) {
          if (hoverMesh && !hoverMesh.userData.spawning) hoverMesh.userData.targetScale = hoverMesh.userData.base.scale || 1;
          hoverMesh = nextHover;
          if (hoverMesh) hoverMesh.userData.targetScale = (hoverMesh.userData.base.scale || 1) * 1.08;
        }
        document.body.style.cursor = hoverMesh ? 'pointer' : 'default';
      }
      // 呼吸动画：只跑可见 + spawning 卡片，隐藏层完全跳过
      const now = performance.now();
      cardMeshes.forEach(mesh => {
        if (mesh.userData.spawning) {
          mesh.lookAt(camera.position);
          return;
        }
        if (!mesh.visible) return;
        mesh.userData.currentScale += (mesh.userData.targetScale - mesh.userData.currentScale) * 0.12;
        mesh.scale.setScalar(mesh.userData.currentScale);
        const baseEuler = mesh.userData.baseEuler;
        const seed = mesh.userData.base.breathSeed || 0;
        mesh.rotation.x = baseEuler.x + Math.sin(now * 0.00028 + seed) * 0.006;
        mesh.rotation.z = baseEuler.z + Math.sin(now * 0.00024 + seed * 0.71) * 0.005;
      });
    }

    let _editingId = null;
    // 朋友圈式 composer · 单一界面，type 由附加的媒体决定
    let attachedKind = 'text'; // 'text' | 'image' | 'video' | 'audio'
    let attachedDataUrl = '';
    let attachedFileName = '';
    let attachedPersistent = true; // 是否能持久化（大文件用 object URL 只能本次会话）
    let selectedLayer = 0; // 0=gentle, 1=companion, 2=inspire

    function openComposer(prefill) {
      _editingId = null;
      attachedKind = 'text';
      attachedDataUrl = '';
      attachedFileName = '';
      attachedPersistent = true;
      const mediaWrap = document.getElementById('composerMedia');
      mediaWrap.innerHTML = '';
      document.getElementById('clearMedia').hidden = true;

      if (prefill && prefill.id) {
        _editingId = prefill.id;
        titleInput.value = prefill.title || '';
        textInput.value = prefill.text || '';
        selectedLayer = Number.isInteger(prefill.layer) ? prefill.layer
                      : (prefill.warmth >= 5 ? 2 : prefill.warmth >= 4 ? 1 : 0);
        if (prefill.src && ['image','video','audio'].includes(prefill.type)) {
          attachedKind = prefill.type;
          attachedDataUrl = prefill.src;
          attachedFileName = prefill.fileName || '';
          attachedPersistent = !prefill.src.startsWith('blob:');
          renderAttachedPreview();
        }
      } else {
        titleInput.value = '';
        textInput.value = '';
        selectedLayer = currentLayer || 0;
      }
      document.querySelectorAll('#layerTags button').forEach(b => {
        b.classList.toggle('active', Number(b.dataset.layer) === selectedLayer);
      });

      closeReader();
      composer.classList.add('open');
      overlay.classList.add('on');
      setTimeout(() => textInput.focus(), 120);
    }

    function renderAttachedPreview() {
      const mediaWrap = document.getElementById('composerMedia');
      if (!attachedDataUrl || attachedKind === 'text') {
        mediaWrap.innerHTML = '';
        document.getElementById('clearMedia').hidden = true;
        return;
      }
      let inner = '';
      if (attachedKind === 'image') inner = `<img src="${attachedDataUrl}" alt="">`;
      else if (attachedKind === 'video') inner = `<video src="${attachedDataUrl}" controls playsinline></video>`;
      else if (attachedKind === 'audio') inner = `<audio src="${attachedDataUrl}" controls></audio>`;
      if (!attachedPersistent) {
        inner += `<div class="big-file-note">文件较大 · 本次预览有效，刷新后会失</div>`;
      }
      mediaWrap.innerHTML = inner;
      document.getElementById('clearMedia').hidden = false;
    }

    function clearAttached() {
      // 释放 object URL（如果是的话）
      if (attachedDataUrl && attachedDataUrl.startsWith('blob:')) {
        URL.revokeObjectURL(attachedDataUrl);
      }
      attachedKind = 'text';
      attachedDataUrl = '';
      attachedFileName = '';
      attachedPersistent = true;
      renderAttachedPreview();
      // 清空所有 file input
      document.querySelectorAll('#mediaRow input[type="file"]').forEach(i => i.value = '');
    }

    function stopMediaIn(container) {
      if (!container) return;
      container.querySelectorAll('video, audio').forEach(el => {
        try {
          el.pause();
          el.currentTime = 0;
          el.removeAttribute('src');
          el.load();
        } catch {}
      });
    }

    function closeComposer() {
      stopMediaIn(composer); // 立刻停掉预览里的视频/音频，不让它在后台继续播
      composer.classList.remove('open');
      overlay.classList.remove('on');
      if (window.MS?.notifyComposerClosed) window.MS.notifyComposerClosed({ dirty: true });
    }

    // 父 App 列表点 +/编辑触发：直接弹本星 composer
    window.__msOpenComposer = function(editIdx) {
      if (typeof editIdx !== 'number' || editIdx < 0) {
        openComposer();
      } else {
        try {
          const arr = JSON.parse(localStorage.getItem('memory-sparks:healing-records') || '[]');
          if (arr[editIdx]) openComposer(arr[editIdx]); else openComposer();
        } catch { openComposer(); }
      }
    };

    const READER_SHAPES = ['shape-text', 'shape-audio', 'shape-image-h', 'shape-image-v', 'shape-video-h', 'shape-video-v'];
    function setReaderShape(record) {
      READER_SHAPES.forEach(c => reader.classList.remove(c));
      if (!record) { reader.classList.add('shape-text'); return; }
      // audio 永远是 1:1，无论有没有 src
      if (record.type === 'audio') {
        reader.classList.add('shape-audio');
        return;
      }
      // text 或 image/video 但没有 src（demo）→ 文本形状
      if (record.type === 'text' || !record.src) {
        reader.classList.add('shape-text');
        return;
      }
      // image / video：先临时按横向，异步测真实比例后再切
      const isVideo = record.type === 'video';
      const tentative = isVideo ? 'shape-video-h' : 'shape-image-h';
      reader.classList.add(tentative);
      if (isVideo) {
        const v = document.createElement('video');
        v.preload = 'metadata';
        v.muted = true;
        v.addEventListener('loadedmetadata', () => {
          if (!reader.classList.contains('open')) return;
          const finalShape = v.videoWidth >= v.videoHeight ? 'shape-video-h' : 'shape-video-v';
          READER_SHAPES.forEach(c => reader.classList.remove(c));
          reader.classList.add(finalShape);
        }, { once: true });
        v.src = record.src;
      } else {
        const img = new Image();
        img.addEventListener('load', () => {
          if (!reader.classList.contains('open')) return;
          const finalShape = img.naturalWidth >= img.naturalHeight ? 'shape-image-h' : 'shape-image-v';
          READER_SHAPES.forEach(c => reader.classList.remove(c));
          reader.classList.add(finalShape);
        }, { once: true });
        img.src = record.src;
      }
    }

    let _readerCurrentId = null;
    function openReader(id) {
      const record = records.find(item => item.id === id);
      if (!record) return;
      _readerCurrentId = id;
      setReaderShape(record);
      document.getElementById('readerMedia').innerHTML = mediaHtml(record);
      document.getElementById('readerTitle').textContent = record.title || '没有标题的微光';
      document.getElementById('readerText').textContent = record.text || '';
      reader.classList.add('open');
      overlay.classList.add('on');
      // 挂统一编辑/删除按钮
      if (window.MS && MS.bindEdit) {
        MS.bindEdit({
          container: reader,
          getId: () => _readerCurrentId,
          label: '再写一笔',
          onEdit: (rid) => {
            const r = records.find(x => x.id === rid);
            if (!r) return;
            closeReader();
            openComposer(r);
          },
        });
      }
      if (window.MS && MS.bindDelete) {
        MS.bindDelete({
          container: reader,
          getId: () => _readerCurrentId,
          question: '熄灭这道微光？',
          yes: '熄灭',
          onDelete: (rid) => {
            records = records.filter(r => r.id !== rid);
            saveRecords();
            closeReader();
            buildCards();
          },
        });
      }
    }

    function closeReader() {
      stopMediaIn(reader); // 立刻停掉视频/音频播放，不让它在后台继续出声
      const mediaWrap = document.getElementById('readerMedia');
      if (mediaWrap) mediaWrap.innerHTML = ''; // 彻底释放，避免下次打开还残留
      reader.classList.remove('open');
      overlay.classList.remove('on');
      READER_SHAPES.forEach(c => reader.classList.remove(c));
    }

    function mediaHtml(record) {
      if (record.src && record.type === 'image') return `<img src="${record.src}" alt="">`;
      if (record.src && record.type === 'video') return `<video src="${record.src}" controls playsinline></video>`;
      if (record.src && record.type === 'audio') return `<audio src="${record.src}" controls style="width:78%; margin:96px 11%;"></audio>`;
      return '';
    }

    // 小文件用 base64（可持久化到 localStorage）；大文件回退到 object URL（本次会话有效，刷新即失）
    const DATAURL_LIMIT = 1.4 * 1024 * 1024; // 1.4MB
    function readFileAsDataUrl(file) {
      return new Promise(resolve => {
        if (!file) return resolve({ url: '', persistent: false });
        if (file.size > DATAURL_LIMIT) {
          const url = URL.createObjectURL(file);
          resolve({ url, persistent: false });
          return;
        }
        const reader = new FileReader();
        reader.onload = () => resolve({ url: reader.result, persistent: true });
        reader.onerror = () => resolve({ url: '', persistent: false });
        reader.readAsDataURL(file);
      });
    }

    async function addMemory() {
      const hasContent = titleInput.value.trim() || textInput.value.trim() || attachedDataUrl;
      if (!hasContent) { textInput.focus(); return; }
      // type 自动判断：有媒体 → 媒体类型，纯文字 → text
      const finalType = attachedKind;
      // warmth 映射保持兼容（旧逻辑读 warmth），但主键已经是 layer
      const layerToWarmth = [3, 4, 5];

      if (_editingId) {
        const idx = records.findIndex(r => r.id === _editingId);
        if (idx >= 0) {
          const orig = records[idx];
          records[idx] = {
            ...orig,
            title: titleInput.value.trim() || orig.title,
            text: textInput.value.trim(),
            type: finalType,
            src: attachedDataUrl || (finalType === orig.type ? orig.src : ''),
            fileName: attachedFileName || orig.fileName,
            layer: selectedLayer,
            warmth: layerToWarmth[selectedLayer],
          };
          saveRecords();
          // 不 reload：保留内存里的 blob: URL（loadRecords 会触发 saveRecords 的 strip）
          buildCards(_editingId);
          _editingId = null;
        }
      } else {
        const record = {
          id: `healing-${Date.now()}`,
          title: titleInput.value.trim() || '刚刚放进来的微光',
          text: textInput.value.trim(),
          type: finalType,
          src: attachedDataUrl,
          fileName: attachedFileName,
          layer: selectedLayer,
          warmth: layerToWarmth[selectedLayer],
          date: formatToday()
        };
        // 保留内存中的 demo + 用户记录顺序，仅在前面插入新 record；不 reload 避免 blob URL 被 strip
        const userRecs = records.filter(r => !r.id.startsWith('demo-'));
        const demoRecs = records.filter(r => r.id.startsWith('demo-'));
        records = [record, ...userRecs, ...demoRecs];
        saveRecords();

        // 跨层：先切层（等层过渡跑完），再 buildCards + flyInNewCard
        if (selectedLayer !== currentLayer) {
          closeComposer();
          await goToLayer(selectedLayer);
        }
        buildCards(record.id);
        flyInNewCard(record.id);
      }
      titleInput.value = '';
      textInput.value = '';
      attachedKind = 'text';
      attachedDataUrl = '';
      attachedFileName = '';
      attachedPersistent = true;
      document.getElementById('composerMedia').innerHTML = '';
      document.getElementById('clearMedia').hidden = true;
      document.querySelectorAll('#mediaRow input[type="file"]').forEach(i => i.value = '');
      closeComposer();
      hud.classList.add('soft');
    }

    function formatToday() {
      const now = new Date();
      return `${now.getFullYear()}.${String(now.getMonth() + 1).padStart(2, '0')}.${String(now.getDate()).padStart(2, '0')}`;
    }

    // P3 性能：延迟 800ms 启动 WebGL，给父 App 转场动画让出 GPU 资源
    setTimeout(init, 800);
    })().catch(error => {
      console.error(error);
      document.getElementById('fallback')?.classList.add('on');
    });
  </script>

<script>
  // ── Memory Sparks · 统一组件挂载（介绍卡 + 添加按钮） ──
  // 在 DOM ready 后挂载，避免被原有 init 顺序覆盖
  (function bootMSShared() {
    function go() { if (window.MS && window.MS.bootstrap) MS.bootstrap('healing'); else setTimeout(go, 60); }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', go);
    else go();
  })();
</script>
