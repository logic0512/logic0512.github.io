<body>
  <canvas id="stage" aria-label="治愈星三维记忆云"></canvas>
  <div class="layer-title" id="layerTitle" aria-hidden="true"></div>
  <aside class="hud" id="hud">
    <h1>治愈星</h1>
    <p class="hint">拖动环顾　↑ 深入　↓ 回返</p>
  </aside>
  <button class="add" id="addBtn" data-open-composer type="button" aria-label="放一颗微光进来">
    <span class="plus">+</span><span>放一颗微光</span>
  </button>
  <div class="empty" id="empty">
    <p class="empty-line">这里还没有微光</p>
    <button class="empty-add" id="emptyAdd" data-open-composer type="button">放一颗进来</button>
  </div>
  <div class="overlay" id="overlay"></div>

  <section class="panel composer" id="composer" aria-label="新增治愈时刻">
    <div class="panel-head">
      <h2 class="panel-title">放一颗微光进来</h2>
      <button class="close" id="closeComposer" type="button" aria-label="关闭">×</button>
    </div>
    <input id="memoryTitle" type="text" maxlength="36" placeholder="给这个时刻起一个名字（可选）">
    <textarea id="memoryText" maxlength="420" placeholder="写下来吧，想到什么都可以。"></textarea>
    <div class="composer-media" id="composerMedia"></div>
