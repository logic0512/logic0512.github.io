      { id: 'demo-28', title: '看到对方眼里的我', text: '原来在他眼里，我是值得被珍惜的样子。', type: 'text', warmth: 5, date: '2025.10.07' },
      { id: 'demo-29', title: '听完一首歌', text: '安静地听到最后一秒，没有快进，没有切换。', type: 'audio', warmth: 4, duration: 215, date: '2025.09.28' },
      { id: 'demo-30', title: '整理书桌', text: '一边收拾一边发现，自己也在被整理。', type: 'text', warmth: 3, date: '2025.09.20' },
      { id: 'demo-31', title: '走进澡堂的瞬间', text: '热气一裹上来，今天就先到这里。', type: 'text', warmth: 4, date: '2025.09.12' },
